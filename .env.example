# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Candidate Search API ────────────────────────────────────────────────────
# Required. Rotate immediately if you suspect it has been exposed.
CANDIDATE_SEARCH_API_KEY=your_api_key_here

# ── Anthropic (Claude summaries) ────────────────────────────────────────────
# Optional. If blank, candidate summaries are skipped and qualitySignals are used.
ANTHROPIC_API_KEY=your_anthropic_key_here

# Model to use for candidate summarisation (defaults to claude-haiku-4-5-20251001).
# Update this when Anthropic retires a model version.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Proxy / API security ─────────────────────────────────────────────────────
# Shared secret between the frontend and the API handlers (api/*.js / proxy.mjs).
# Set the same value here AND as VITE_PROXY_SECRET so the frontend can send it.
# If blank, the endpoints accept all requests (only safe when behind localhost CORS).
PROXY_API_SECRET=generate-a-random-secret-here

# Must match PROXY_API_SECRET above — Vite bakes this into the frontend bundle.
VITE_PROXY_SECRET=generate-a-random-secret-here

# ── CORS (Vercel / production deployments only) ──────────────────────────────
# Set this to your production frontend origin, e.g. https://catalogue.ajt.my
# If blank, the API handlers omit the Access-Control-Allow-Origin header.
ALLOWED_ORIGIN=https://your-production-domain.com

# ── Express dev proxy ────────────────────────────────────────────────────────
# Port for proxy.mjs (default: 3001)
PROXY_PORT=3001
